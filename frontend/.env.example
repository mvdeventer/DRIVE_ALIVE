# Frontend Environment Variables
# Copy this file to .env and fill in your values
# DO NOT commit .env to git - it contains sensitive information

# API Configuration
EXPO_PUBLIC_API_URL=http://localhost:8000

# ── Debug Mode (Development only — NEVER true in production) ───────────────────
# Activate with:  s.bat --debug   or   s.bat start --debug
# When true, all forms are pre-filled from the values below.
EXPO_PUBLIC_DEBUG_MODE=false

# ── Admin account ─────────────────────────────────────────────────────────────
EXPO_PUBLIC_DEBUG_ADMIN_FIRST_NAME=
EXPO_PUBLIC_DEBUG_ADMIN_LAST_NAME=
EXPO_PUBLIC_DEBUG_EMAIL=
EXPO_PUBLIC_DEBUG_PHONE=
EXPO_PUBLIC_DEBUG_ADMIN_ID_NUMBER=
EXPO_PUBLIC_DEBUG_ADMIN_ADDRESS=
EXPO_PUBLIC_DEBUG_PASSWORD=

# ── Student test account ──────────────────────────────────────────────────────
EXPO_PUBLIC_DEBUG_STUDENT_EMAIL=
EXPO_PUBLIC_DEBUG_STUDENT_PHONE=

# ── SMTP / Gmail ──────────────────────────────────────────────────────────────
EXPO_PUBLIC_DEBUG_SMTP_EMAIL=
EXPO_PUBLIC_DEBUG_SMTP_PASSWORD=

# ── Twilio / WhatsApp ─────────────────────────────────────────────────────────
EXPO_PUBLIC_DEBUG_TWILIO_SID=
EXPO_PUBLIC_DEBUG_TWILIO_TOKEN=
EXPO_PUBLIC_DEBUG_TWILIO_SENDER_PHONE=
EXPO_PUBLIC_DEBUG_TWILIO_TEST_PHONE=
